# Backend URL — points to the shared sbdc-advisor FastAPI backend
# In development: http://localhost:8000
# In production: your Railway backend URL
BACKEND_URL=http://localhost:8000

# Port — Railway sets this automatically
# PORT=3000

# Claude AI — powers content generation tools
# (success stories, social media, newsletters, webpage copy, email templates)
# Get your key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# App password — gates access to the entire app
# When set, users must enter this password at /login before accessing any page.
# Leave unset to disable password protection (e.g. during local dev).
# APP_PASSWORD=your-shared-password-here

# App secret — used to sign session cookies (optional)
# If not set, APP_PASSWORD is used as the signing key.
# APP_SECRET=some-random-secret-string

# Inject password — optional second password that grants a session scoped
# to ONLY the R4I inject tool (/admin/inject-r4i), so program staff can
# backfill records without the full admin password.
# INJECT_PASSWORD=another-password-here

# Neoserra CRM — direct API access for PIN (custom form) creation
# Required for TFG Application 2026 PIN form population after client creation.
# NEOSERRA_BASE_URL=https://norcal.neoserra.com
# NEOSERRA_API_KEY=your-api-key-here

# Resend — transactional email delivery
# Get your key at https://resend.com
# RESEND_API_KEY=re_...

# Resend "From" address for California SBDC programs (R4I, etc.)
# Requires the californiasbdc.org domain to be verified in Resend.
# RESEND_FROM_SBDC=California SBDC <noreply@californiasbdc.org>

# Public URL — used to generate links in notification emails
# In production: your Railway deployment URL
# APP_URL=https://mysbdc-tools-production.up.railway.app

# Google Drive — pitch deck storage
# Service account credentials JSON (base64-encoded)
# Create at https://console.cloud.google.com → Service Accounts
# GOOGLE_SERVICE_ACCOUNT_KEY=eyJ0eXBlIjoi...
# Shared folder ID where pitch decks are uploaded
# GOOGLE_DRIVE_FOLDER_ID=1abc...

# TFG application data directory (Railway persistent volume)
# TFG_DATA_DIR=/data/tfg-applications

# ── Network Map (/network-map) ──
# MapTiler basemap key — public by design (ships in the client bundle), so it
# MUST be origin-restricted in the MapTiler dashboard to the production and
# preview domains. NOTE: NEXT_PUBLIC_ vars are inlined at BUILD time, so set
# this in Railway before building; rotating the key requires a redeploy.
# See docs/network-map.md for the key runbook.
# NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# Optional separate server-side key for /api/geocode's MapTiler fallback
# (the primary geocoder is the keyless US Census service). If unset, the
# route falls back to NEXT_PUBLIC_MAPTILER_KEY.
# MAPTILER_API_KEY=your-maptiler-key

# ── Marketing Engine (event promo pipeline) ──
# Rebrandly — sbdc.events shortlinks. Key from https://app.rebrandly.com/account/api
# REBRANDLY_API_KEY=your-rebrandly-api-key
# REBRANDLY_DOMAIN=sbdc.events

# Google Sheet used as the pipeline's system of record.
# Share the Sheet (Editor) with the service account email from
# GOOGLE_SERVICE_ACCOUNT_KEY, and create a tab named "Events".
# SHEET_ID=1AbC...

# Bearer token for cron/workers calling /api/pipeline/* routes.
# Generate with: openssl rand -hex 32
# PIPELINE_SERVICE_TOKEN=long-random-string
